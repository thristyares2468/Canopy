{
  "manifest_version": 3,
  "name": "Canopy",
  "description": "Spatial tabs, spaces, and private Canopy browser settings.",
  "version": "0.2.0",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "contentSettings",
    "downloads",
    "sidePanel",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Canopy sidebar"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_side_panel": {
      "description": "Open the Canopy sidebar",
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["gestures.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
